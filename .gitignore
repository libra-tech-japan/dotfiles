# --- System & Logs ---
.DS_Store
.install.lock
*.swp
*.bak
*.log
.history/

# --- Private Configs ---
.user_config/
.ssh/
.netrc
.gitconfig.local
.zshrc-local

# --- Editor & IDE ---
.idea/

# --- Language & Runtime Caches ---
node_modules/
dist/
build/
.mise/
.python-version
__pycache__/

# --- Application Caches (any */.config/ under Stow packages) ---
**/.config/configstore/
**/.config/gh/
**/.config/coc/
**/.config/yarn/
**/.config/iterm2/
**/.config/htop/

# install 誤配置の防止（starship/.config 内への symlink）
starship/.config/lazygit
starship/.config/mise
starship/.config/nvim
starship/.config/tmux

# link_config_entries の ln -sf 誤作動で作られる入れ子 symlink（ln -sfn で修復済み）
**/.config/tmuxinator/tmuxinator
**/.config/lazygit/lazygit
**/.config/nvim/nvim
**/.config/mise/mise
**/.config/tmux/tmux

# --- Tmux Plugins (TPM 既定は ~/.tmux/plugins。config 配下に入った場合の保険) ---
tmux/.config/tmux/plugins/
