[core]
	pager = delta
	excludesfile = ~/.gitignore_global

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true

[diff]
	tool = difftastic

[difftool]
	prompt = false

[difftool "difftastic"]
	cmd = difft --color=always "$LOCAL" "$REMOTE"

[alias]
	dft = difftool
	lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit --date=relative
  a = add
	st = status
	sw = switch
	co = checkout
	br = branch
  ps = push
  pl = pull
  pf = pull --ff-only
  ca = commit --amend
  cm = commit -m

[secrets]
	providers = git secrets --aws-provider
	patterns = (A3T[A-Z0-9]|AKIA|AGPA|AIDA|AROA|AIPA|ANPA|ANVA|ASIA)[A-Z0-9]{16}
	patterns = (\"|')?(AWS|aws|Aws)?_?(SECRET|secret|Secret)?_?(ACCESS|access|Access)?_?(KEY|key|Key)(\"|')?\\s*(:|=>|=)\\s*(\"|')?[A-Za-z0-9/\\+=]{40}(\"|')?
	patterns = (\"|')?(AWS|aws|Aws)?_?(ACCOUNT|account|Account)_?(ID|id|Id)?(\"|')?\\s*(:|=>|=)\\s*(\"|')?[0-9]{4}\\-?[0-9]{4}\\-?[0-9]{4}(\"|')?

[user]
	# 個人情報（name/email）は公開リポジトリに載せず ~/.gitconfig.local に置き、下の [include] で読み込む。
	# useConfigOnly=true は identity 未設定時に git が username@hostname から著者情報を
	# 勝手に生成してコミットするのを防ぐ（実名・実メールの意図せぬ混入と誤 author を防止）。
	useConfigOnly = true

[include]
	path = ~/.gitconfig.local

[ghq]
	root = ~/.ghq
[credential "https://github.com"]
	helper =
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !gh auth git-credential
